# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# API Configuration
API_URL=http://api:8000
API_PORT=8000

# Frontend Configuration
FRONTEND_PORT=3000

# Worker Configuration
WORKER_TIMEOUT=5

# Docker Registry (for CI/CD)
REGISTRY_URL=ghcr.io/OWNER                # replace OWNER with your GitHub username or org
IMAGE_TAG=latest
